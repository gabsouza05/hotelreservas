generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Quarto {
  id       Int      @id @default(autoincrement())
  numero   String
  tipo     String

  reservas Reserva[]
}

model Reserva {
  id          Int      @id @default(autoincrement())
  hospede     String
  dataEntrada DateTime
  dataSaida   DateTime
  criacao     DateTime @default(now())

  quartoId Int
  quarto   Quarto @relation(fields: [quartoId], references: [id])
}